# =============================================================================
# .gitignore — VoiceBot Gateway (vbgw)
# =============================================================================

# ── C++ 빌드 산출물 ──────────────────────────────────────────
build/
CMakeCache.txt
CMakeFiles/
cmake_install.cmake
compile_commands.json
*.o
*.a
*.so
*.so.*
*.dylib

# ── Protobuf 자동 생성 파일 (원본: protos/*.proto) ─────────────
generated/

# ── 실행 바이너리 ─────────────────────────────────────────────
vbgw
/vbgw

# ── Python 가상환경 ───────────────────────────────────────────
.venv/
venv/
env/
src/emulator/venv/

# ── Python 캐시 ───────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
.ruff_cache/

# ── Python emulator 자동 생성 (proto 컴파일 결과) ──────────────
src/emulator/voicebot_pb2.py
src/emulator/voicebot_pb2_grpc.py

# ── ML 모델 (바이너리, 별도 관리) ────────────────────────────
# models/ 폴더는 필요 시 LFS 또는 별도 스토리지 사용
# models/*.onnx  ← 현재는 추적 (소규모), 필요 시 주석 해제

# ── IDE / 에디터 ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# ── OS 메타 파일 ──────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── 보안 민감 파일 ────────────────────────────────────────────
.env
.env.*
*.env
*.pem
*.key
*.crt
*.cert
*.p12
*.pfx
secrets/
credentials.json

# ── 로그 / 임시 파일 ──────────────────────────────────────────
*.log
logs/
tmp/
temp/
*.tmp
*.bak
*.orig

# ── 테스트 커버리지 ───────────────────────────────────────────
.coverage
htmlcov/
.pytest_cache/
test-results/

# ── CMake 의존성 추적 (대용량, 재생성 가능) ───────────────────
**/*.o.d
**/compiler_depend.*
